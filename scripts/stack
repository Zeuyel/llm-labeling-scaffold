#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required but was not found in PATH." >&2
  exit 1
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "docker compose is required but is not available." >&2
  exit 1
fi

if [ ! -f .env ]; then
  cp .env.example .env
  echo "已从 .env.example 创建 .env"
fi

env_value() {
  local name="$1"
  local fallback="$2"
  local value="${!name:-}"

  if [ -z "$value" ]; then
    value="$(grep -E "^${name}=" .env 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi

  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

usage() {
  cat >&2 <<'EOF'
用法：scripts/stack [up|down|logs|ps|restart] [--mlflow]

默认启动 light panel 和 Argilla 标注服务。
如需可选模型记录服务，使用：scripts/stack up --mlflow
EOF
}

cmd="${1:-up}"
if [ "$#" -gt 0 ]; then
  shift
fi

enable_mlflow=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mlflow|--profile=mlflow)
      enable_mlflow=1
      shift
      ;;
    --profile)
      if [ "${2:-}" = "mlflow" ]; then
        enable_mlflow=1
        shift 2
      else
        usage
        exit 2
      fi
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

compose=(docker compose)
services=(panel argilla argilla-worker argilla-postgres elasticsearch redis)
if [ "$enable_mlflow" -eq 1 ]; then
  compose+=(--profile mlflow)
  services+=(mlflow)
fi

print_urls() {
  echo
  echo "light panel： http://localhost:$(env_value PANEL_PORT 8765)"
  echo "Argilla：     http://localhost:$(env_value ARGILLA_PORT 6900)"
  if [ "$enable_mlflow" -eq 1 ]; then
    echo "模型记录服务： http://localhost:$(env_value MLFLOW_PORT 5000)"
  fi
  echo
  echo "panel 登录：admin / $(env_value LLS_PANEL_PASSWORD changeme)"
  echo "Argilla 登录：$(env_value ARGILLA_USERNAME argilla) / $(env_value ARGILLA_PASSWORD 12345678)"
  if [ "$enable_mlflow" -eq 0 ]; then
    echo
    echo "默认未启动模型记录服务；需要时运行：scripts/stack up --mlflow"
  fi
}

case "$cmd" in
  up)
    if [ "$enable_mlflow" -eq 1 ]; then
      MLFLOW_TRACKING_URI="${MLFLOW_TRACKING_URI:-http://mlflow:5000}" "${compose[@]}" up -d --build
    else
      "${compose[@]}" up -d --build
    fi
    print_urls
    ;;
  down)
    "${compose[@]}" down
    ;;
  logs)
    "${compose[@]}" logs -f "${services[@]}"
    ;;
  ps)
    "${compose[@]}" ps
    ;;
  restart)
    if [ "$enable_mlflow" -eq 1 ]; then
      MLFLOW_TRACKING_URI="${MLFLOW_TRACKING_URI:-http://mlflow:5000}" "${compose[@]}" restart "${services[@]}"
    else
      "${compose[@]}" restart "${services[@]}"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
