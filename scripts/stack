#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required but was not found in PATH." >&2
  exit 1
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "docker compose is required but is not available." >&2
  exit 1
fi

if [ ! -f .env ]; then
  cp .env.example .env
  echo "Created .env from .env.example"
fi

env_value() {
  local name="$1"
  local fallback="$2"
  local value="${!name:-}"

  if [ -z "$value" ]; then
    value="$(grep -E "^${name}=" .env 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi

  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

case "${1:-up}" in
  up)
    docker compose up -d --build
    echo
    echo "Pipeline control panel: http://localhost:$(env_value PANEL_PORT 8765)"
    echo "Argilla:                http://localhost:$(env_value ARGILLA_PORT 6900)"
    echo "MLflow:                 http://localhost:$(env_value MLFLOW_PORT 5000)"
    echo
    echo "Panel login: admin / $(env_value LLS_PANEL_PASSWORD changeme)"
    echo "Argilla login: $(env_value ARGILLA_USERNAME argilla) / $(env_value ARGILLA_PASSWORD 12345678)"
    ;;
  down)
    docker compose down
    ;;
  logs)
    docker compose logs -f panel argilla mlflow
    ;;
  ps)
    docker compose ps
    ;;
  restart)
    docker compose restart panel argilla mlflow
    ;;
  *)
    echo "Usage: scripts/stack [up|down|logs|ps|restart]" >&2
    exit 2
    ;;
esac
