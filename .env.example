PANEL_PORT=8765
LLS_PANEL_PASSWORD=changeme

ARGILLA_PORT=6900
ARGILLA_USERNAME=argilla
ARGILLA_PASSWORD=12345678
ARGILLA_API_KEY=argilla.apikey
ARGILLA_WORKSPACE=argilla
ARGILLA_BACKGROUND_WORKERS=2

# 低配测试机默认给 Elasticsearch 较小堆内存；生产机器建议调高到 -Xms512m -Xmx512m。
ELASTICSEARCH_JAVA_OPTS=-Xms256m -Xmx256m

# 可选模型记录服务，仅在启用 mlflow profile 时使用。
MLFLOW_PORT=5000
# 默认不向 panel 注入模型记录地址；scripts/stack up --mlflow 会临时设置。
# MLFLOW_TRACKING_URI=http://mlflow:5000

# 数据湖导入使用 rclone。Docker 部署时请把只读 rclone.conf 映射到容器内这个路径。
# RCLONE_CONFIG=/run/secrets/rclone/rclone.conf
LLS_RCLONE_TIMEOUT_SECONDS=120

PIP_INDEX_URL=https://repo.huaweicloud.com/repository/pypi/simple
PIP_TRUSTED_HOST=repo.huaweicloud.com
