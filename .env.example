PANEL_PORT=8765
LLS_PANEL_PASSWORD=changeme

ARGILLA_PORT=6900
ARGILLA_USERNAME=argilla
ARGILLA_PASSWORD=12345678
ARGILLA_API_KEY=argilla.apikey
ARGILLA_WORKSPACE=argilla
ARGILLA_BACKGROUND_WORKERS=2

# 低配测试机默认给 Elasticsearch 较小堆内存；生产机器建议调高到 -Xms512m -Xmx512m。
ELASTICSEARCH_JAVA_OPTS=-Xms256m -Xmx256m

# 可选模型记录服务，仅在启用 Docker Compose 的 mlflow profile 时使用。
MLFLOW_PORT=5000
# 默认不向 panel 注入模型记录地址；scripts/stack up --mlflow 会临时设置。
# MLFLOW_TRACKING_URI=http://mlflow:5000

# 数据湖导入和任务同步只通过 rclone 访问 R2。
# 首次部署后请在“系统设置”填写 task_registry_uri 和 data_lake_r2_prefix，再同步任务配置。
LLS_TASK_SOURCE=r2
# 必须改为本部署自己的 R2 registry；下面是占位格式，不是可直接使用的 bucket。
LLS_TASK_REGISTRY_URI=r2:YOUR_BUCKET/governance/data_lake/v1/current/data_lake.yaml
LLS_DATA_LAKE_R2_PREFIX=r2:YOUR_BUCKET/
# 示例：
# LLS_TASK_REGISTRY_URI=r2:my-labeling-lake/governance/data_lake/v1/current/data_lake.yaml
# LLS_DATA_LAKE_R2_PREFIX=r2:my-labeling-lake/
# Docker 部署时请把宿主机 rclone.conf 只读映射到容器，不要把密钥写进镜像。
# RCLONE_CONFIG_HOST=${HOME}/.config/rclone/rclone.conf
# RCLONE_CONFIG=/run/secrets/rclone/rclone.conf
LLS_RCLONE_TIMEOUT_SECONDS=120
# 生产默认不允许面板覆盖数据湖来源；只在开发排查时设置为 1。
# LLS_ALLOW_DATA_LAKE_OVERRIDES=1
# 生产默认只允许访问 LLS_DATA_LAKE_R2_PREFIX 下的 R2 URI；本地路径只给单测使用。
# LLS_ALLOW_LOCAL_DATA_LAKE_URIS=1

PIP_INDEX_URL=https://repo.huaweicloud.com/repository/pypi/simple
PIP_TRUSTED_HOST=repo.huaweicloud.com
